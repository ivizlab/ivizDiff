# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# ── Models & large weights (download separately — see docs/INSTALL.md) ────────
# Folder structure is committed via .gitkeep; model files are not.
*.safetensors
*.ckpt
*.pt
*.bin
*.onnx
models/**
!models/**/.gitkeep
engines/**
!engines/.gitkeep

# ── User output — folders exist in repo via .gitkeep, content is not committed ─
snapshots/*
!snapshots/.gitkeep
videos/*
!videos/.gitkeep
images/outputs/*
!images/outputs/.gitkeep
images/inputs/*
!images/inputs/input.png          # default style image is committed
!images/inputs/.gitkeep

# ── Frontend build output ──────────────────────────────────────────────────────
frontend/node_modules/
frontend/public/
frontend/.svelte-kit/

# ── Recording output ───────────────────────────────────────────────────────────
*.webm
*.mp4

# ── Configs — user configs are personal, examples are committed ───────────────���
configs/*.yaml
configs/*.yml
!configs/NewStart.yaml
!configs/_examples/

# ── IDE / OS ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db

# ── Misc ───────────────────────────────────────────────────────────────────────
*.log
.env
notes/
